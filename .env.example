# ═══════════════════════════════════════════════════════════════════════════
# AI 模型选择器 - 环境变量配置模板
# ═══════════════════════════════════════════════════════════════════════════
# 
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填入你的 API Key
# 3. 确保 .env 已加入 .gitignore
#
# 注意：
# - 所有 Key 都可选，未配置的平台将使用缓存数据或硬编码列表
# - GitHub Actions 通过 Secrets 注入，无需本地配置
# - 这些 Key 仅用于获取公开的模型列表和价格信息
# ═══════════════════════════════════════════════════════════════════════════

# ─── 国内平台 ───
SF_KEY=              # 硅基流动 - https://cloud.siliconflow.cn
ALIYUN_KEY=          # 阿里百炼 - https://dashscope.console.aliyun.com
MS_KEY=              # 月之暗面 - https://platform.moonshot.cn
ZH_KEY=              # 智谱 AI - https://open.bigmodel.cn
VOLC_KEY=            # 火山引擎 - https://console.volcengine.com/ark
TENCENT_KEY=         # 腾讯混元 - https://console.cloud.tencent.com/hunyuan
SPARK_KEY=           # 讯飞星火 - https://xinghuo.xfyun.cn
MINIMAX_KEY=         # MiniMax - https://www.minimaxi.com
YI_KEY=              # 零一万物 - https://platform.lingyiwanwu.com
BAICHUAN_KEY=        # 百川智能 - https://platform.baichuan-ai.com
JIEYUE_KEY=          # 阶跃星辰 - https://platform.stepfun.com
DEEPSEEK_KEY=        # DeepSeek - https://platform.deepseek.com
BAIDU_KEY=           # 百度文心 - https://qianfan.baidubce.com

# ─── 国外平台 ───
GROQ_KEY=            # Groq - https://console.groq.com
TOGETHER_KEY=        # Together AI - https://api.together.xyz
FIREWORKS_KEY=       # Fireworks AI - https://fireworks.ai
COHERE_KEY=          # Cohere - https://dashboard.cohere.com
DEEPINFRA_KEY=       # DeepInfra - https://deepinfra.com
AIHUBMIX_KEY=        # AiHubMix - https://aihubmix.com

# ─── 聚合平台 ───
INFINI_KEY=          # 无问芯穹 - https://cloud.infini-ai.com
NOVITA_KEY=          # Novita AI - https://novita.ai
N1N_KEY=             # n1n.ai - https://n1n.ai
CA_KEY=              # ChatAnywhere - https://chatanywhere.org

# ─── 通知配置（可选） ───
TELEGRAM_BOT_TOKEN=  # Telegram Bot Token（用于每日更新通知）
TELEGRAM_CHAT_ID=    # Telegram Chat ID

# ─── 高级配置（可选） ───
# OUTPUT_FILE=        # 输出文件路径，默认为 index.html
# CACHE_DIR=          # 缓存目录，默认为 .cache
# MODELS_JSON=        # 模型数据 JSON 路径，默认为 models_data.json
